# Copy to .env and set values. Do NOT commit .env or put tokens in version control.
# For Cursor MCP, you can set these in the MCP server's "env" instead.

# Spectrum API (required for API tools)
SPECTRUM_API_BASE_URL=https://login.spectrumoutfitters.com/api

# Admin JWT from web app: DevTools → Application → Local Storage → token
# Required for: spectrum_active_sessions, spectrum_login_events, spectrum_security_stats
SPECTRUM_ADMIN_TOKEN=

# Optional: path to Calendar repo root (for doc resources). Defaults to parent of mcp-server.
# SPECTRUM_PROJECT_ROOT=C:\Users\you\Documents\Spectrum Outfitters\Applications\Spectrum Outfitters Calendar
