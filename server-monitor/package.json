{
  "name": "spectrum-server-monitor",
  "version": "1.0.0",
  "description": "Desktop app that watches the Spectrum Outfitters server and shows health, sessions, and login data",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.spectrumoutfitters.servermonitor",
    "productName": "Spectrum Server Monitor",
    "win": { "target": "nsis" }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
