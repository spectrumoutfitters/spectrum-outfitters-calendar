# Nginx config for raffle.spectrumoutfitters.com
#
# INSTALL:
#   sudo cp raffle.nginx /etc/nginx/sites-available/spectrum-raffle
#   sudo ln -s /etc/nginx/sites-available/spectrum-raffle /etc/nginx/sites-enabled/
#   sudo nginx -t
#   sudo systemctl reload nginx
#
# Then get SSL (free via Certbot):
#   sudo certbot --nginx -d raffle.spectrumoutfitters.com

server {
    listen 80;
    server_name raffle.spectrumoutfitters.com;

    # Certbot will add the HTTPS block below automatically.
    # For now, HTTP works — run certbot to upgrade.

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Next.js static assets — long cache
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header Host $host;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Everything else → Next.js on port 3001
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Timeouts
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
    }
}
