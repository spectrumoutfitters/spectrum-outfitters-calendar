# Production build: base path when deployed under a subpath (e.g. spectrumoutfitters.com/login)
# Copy to .env.production and set your secret path. No trailing slash.
VITE_BASE_PATH=/login

# Optional: only if API is on a different origin (e.g. https://spectrumoutfitters.com/api)
# VITE_API_URL=https://spectrumoutfitters.com/api

# Raffle Next app (Grand Opening Day embed + links in Admin)
# VITE_RAFFLE_ORIGIN=https://raffle.spectrumoutfitters.com
